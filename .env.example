# Optional: use a specific CUPS USB URI rather than automatic discovery.
# Retrieve the URI on the Raspberry Pi with:
#   docker compose exec cups lpinfo -v
# PRINTER_URI=usb://DYMO/LabelWriter%20450?serial=YOUR_PRINTER_SERIAL

# Optional: use a different queue name or supported DYMO model.
# PRINTER_NAME=dymo
# PRINTER_MODEL=dymo:0/cups/model/lw450.ppd
